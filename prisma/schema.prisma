generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  owner
  admin
  member
}

model Account {
  id        String   @id @default(cuid())
  name      String   @default("My Account")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members AccountMember[]
  invites Invite[]
  sites   Site[]

  @@map("accounts")
}

model AccountMember {
  id        String     @id @default(cuid())
  accountId String     @map("account_id")
  userId    String     @map("user_id")
  role      MemberRole @default(member)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@map("account_members")
}

// --- Gate A: Invites ---

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

model Invite {
  id        String       @id @default(cuid())
  accountId String       @map("account_id")
  email     String
  role      MemberRole   @default(member)
  token     String       @unique
  status    InviteStatus @default(pending)
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([token])
  @@map("invites")
}

// --- Gate A: Sites ---

enum SiteStatus {
  active
  archived
}

model Site {
  id            String     @id @default(cuid())
  accountId     String     @map("account_id")
  name          String
  primaryDomain String     @map("primary_domain")
  platformType  String?    @map("platform_type") // shopify, wordpress, custom, etc.
  publicKey     String     @unique @map("public_key")
  secretKey     String     @map("secret_key")
  status        SiteStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([accountId])
  @@index([publicKey])
  @@map("sites")
}

// --- Gate C: Submissions ---

enum SubmissionStatus {
  new_submission @map("new")
  read
  archived
}

model Submission {
  id           String           @id @default(cuid())
  accountId    String           @map("account_id")
  siteId       String           @map("site_id")
  campaignId   String?          @map("campaign_id")
  variantId    String?          @map("variant_id")
  experimentId String?          @map("experiment_id")
  submissionId String           @map("submission_id") // client-generated UUID for idempotency
  email        String?
  phone        String?
  name         String?
  fieldsJson   String           @map("fields_json") // JSON blob of all field values
  status       SubmissionStatus @default(new_submission)
  createdAt    DateTime         @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, submissionId])
  @@index([accountId])
  @@index([siteId])
  @@map("submissions")
}

// --- Gate C: Account Usage ---

model AccountUsage {
  id              String  @id @default(cuid())
  accountId       String  @unique @map("account_id")
  submissionCount Int     @default(0) @map("submission_count")
  overageCount    Int     @default(0) @map("overage_count")
  usageLocked     Boolean @default(false) @map("usage_locked")

  @@map("account_usage")
}
