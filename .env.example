# Core app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/capturely_dev?schema=public
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Runtime security
RUNTIME_SIGNING_SECRET=replace-with-strong-random-secret
CRON_SECRET=replace-with-strong-random-secret

# Stripe billing
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_GROWTH_PRICE_ID=price_growth

# Email (Resend)
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=Capturely <noreply@capturely.io>

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# GrowthBook
GROWTHBOOK_API_HOST=http://localhost:3100
GROWTHBOOK_SECRET_KEY=your_growthbook_secret_key

# Integrations
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_themes,write_script_tags
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# E2E test auth helpers (optional)
PLAYWRIGHT_AUTH_BYPASS=
PLAYWRIGHT_AUTH_COOKIES=[]
